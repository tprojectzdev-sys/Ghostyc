# Linux Mint WoL bridge environment.
# PROTOCOL.md §14 (Config Validation) — these are required.

# Shared bridge token (must match the relay's GHOSTYC_BRIDGE_TOKEN).
GHOSTYC_BRIDGE_TOKEN=

# Where the relay lives. http://… or https://… are accepted; the bridge
# rewrites them to ws:// / wss:// internally for the /ws/bridge endpoint.
RELAY_URL=http://localhost:8080

# Target PC for Wake-on-LAN.
# MAC address — accepts AA:BB:CC:DD:EE:FF or AA-BB-CC-DD-EE-FF (case-insensitive).
PC_MAC_ADDRESS=
# Subnet broadcast address (e.g. 192.168.1.255). NOT 255.255.255.255 —
# routers usually drop the latter. Use the broadcast for the LAN segment
# the PC lives on.
PC_BROADCAST_ADDRESS=192.168.1.255

# Optional: where bridge JSONL logs are written. Defaults to ./logs.
GHOSTYC_BRIDGE_LOG_DIR=./logs
