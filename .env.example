# Ghostyc environment variables (consolidated reference).
# Each component only reads the vars it needs (see PROTOCOL.md §14).
# Copy the relevant lines into apps/<component>/.env for local development.

# === Relay (apps/relay) ===========================================
# Generate strong tokens with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GHOSTYC_CLIENT_TOKEN=
GHOSTYC_AGENT_TOKEN=
GHOSTYC_BRIDGE_TOKEN=
GHOSTYC_ADMIN_PASSWORD=
PORT=8080

# Optional relay tuning
GHOSTYC_LOG_BUFFER_SIZE=500
GHOSTYC_HEARTBEAT_MS=25000
GHOSTYC_HEARTBEAT_TIMEOUT_MS=60000

# Optional persistent log directory. If set and writable, the relay also writes
# JSONL logs to ${GHOSTYC_LOG_DIR}/relay.log with rotation. If unset, relay logs
# are ephemeral (in-memory ring buffer only, lost on restart).
# GHOSTYC_LOG_DIR=/data/logs

# === Windows agent (apps/agent) ===================================
# GHOSTYC_AGENT_TOKEN must match the relay's value above.
# RELAY_URL is the wss:// URL of the relay (use ws:// for local http).
GHOSTYC_AGENT_TOKEN=
RELAY_URL=ws://localhost:8080
PC_NAME=Tokyo-PC

# === Linux Mint WoL bridge (apps/wol-bridge) =====================
# GHOSTYC_BRIDGE_TOKEN must match the relay's value above.
# RELAY_URL is the same relay URL the agent uses; the bridge connects to /ws/bridge.
# PC_MAC_ADDRESS is the target PC's NIC MAC address (Wake-on-LAN destination).
# PC_BROADCAST_ADDRESS is the LAN subnet broadcast for the PC's segment.
GHOSTYC_BRIDGE_TOKEN=
# RELAY_URL=ws://localhost:8080
PC_MAC_ADDRESS=AA:BB:CC:DD:EE:FF
PC_BROADCAST_ADDRESS=192.168.1.255
GHOSTYC_BRIDGE_LOG_DIR=./logs
